# TuniBot — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# This file is safe to commit. NEVER commit .env.local or .env.

# ── Groq ──────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=

# ── Supabase ───────────────────────────────────────────────────────────
# Project URL and keys from:
# https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n Webhook (optional) ────────────────────────────────────────────
# Only needed if you want WhatsApp lead alerts via n8n
N8N_WEBHOOK_URL=
